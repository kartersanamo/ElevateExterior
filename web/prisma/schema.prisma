generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum QuoteStatus {
  PENDING
  QUOTED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum RecurringFrequency {
  MONTHLY
  EVERY_2_MONTHS
  EVERY_3_MONTHS
  EVERY_6_MONTHS
  YEARLY
}

enum EmailTrigger {
  MANUAL
  DAYS_BEFORE_APPOINTMENT
  DAYS_AFTER_APPOINTMENT
  ON_BOOKING_REQUESTED
  ON_BOOKING_CONFIRMED
}

enum EmailAudience {
  ALL_CUSTOMERS
  EMAIL_LIST
}

model AdminUser {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  passwordHash       String
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AvailabilityRule {
  id        String  @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  enabled   Boolean @default(true)

  @@unique([dayOfWeek])
}

model BlockedDate {
  id     String   @id @default(cuid())
  date   DateTime @unique
  reason String?
}

model BlockedTimeSlot {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  reason    String?
  createdAt DateTime @default(now())

  @@index([date])
}

model Booking {
  id                      String        @id @default(cuid())
  status                  BookingStatus @default(PENDING)
  customerName            String
  customerEmail           String
  customerPhone           String
  address                 String
  services                String
  notes                   String?
  scheduledDate           DateTime
  startTime               String
  endTime                 String
  publicToken             String?       @unique
  amountChargedCents      Int?
  completedAt             DateTime?
  paidAt                  DateTime?
  stripeCheckoutSessionId String?
  invoiceNumber           String?
  invoiceHtml             String?
  reviewRequestSentAt     DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  photos           JobPhoto[]
  recurringService RecurringService?
  quoteRequest     QuoteRequest?

  @@index([scheduledDate, status])
  @@index([customerEmail])
  @@index([publicToken])
}

model JobPhoto {
  id        String   @id @default(cuid())
  bookingId String
  filename  String
  mimeType  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model QuoteRequest {
  id                  String      @id @default(cuid())
  publicToken         String      @unique @default(cuid())
  status              QuoteStatus @default(PENDING)
  customerName        String
  customerEmail       String
  customerPhone       String?
  address             String?
  services            String      @default("[]")
  message             String
  quotedAmountCents   Int?
  quoteNotes          String?
  proposedDate        DateTime?
  proposedStartTime   String?
  proposedEndTime     String?
  bookingId           String?     @unique
  quotedAt            DateTime?
  respondedAt         DateTime?
  holdExpiresAt       DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([customerEmail])
  @@index([holdExpiresAt])
}

model RecurringService {
  id              String             @id @default(cuid())
  customerEmail   String
  customerName    String
  customerPhone   String?
  address         String
  services        String
  frequency       RecurringFrequency
  active          Boolean            @default(true)
  sourceBookingId String?            @unique
  nextServiceDate      DateTime?
  lastServiceDate      DateTime?
  preferredStartTime   String?
  preferredEndTime     String?
  notes                String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  sourceBooking Booking? @relation(fields: [sourceBookingId], references: [id], onDelete: SetNull)

  @@index([customerEmail])
  @@index([active, nextServiceDate])
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  address   String?
  source    String   @default("booking")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id          String   @id @default(cuid())
  src         String
  storageKey  String?
  alt         String
  category  String
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  bodyHtml  String
  bodyText  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  automations EmailAutomation[]
}

model EmailList {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     EmailListMember[]
  automations EmailAutomation[]
}

model EmailListMember {
  id        String   @id @default(cuid())
  listId    String
  email     String
  name      String?
  createdAt DateTime @default(now())

  list EmailList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, email])
  @@index([email])
}

model EmailAutomation {
  id         String        @id @default(cuid())
  name       String
  enabled    Boolean       @default(true)
  trigger    EmailTrigger
  daysOffset Int?
  audience   EmailAudience @default(ALL_CUSTOMERS)
  templateId String
  listId     String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  template EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  list     EmailList?    @relation(fields: [listId], references: [id], onDelete: SetNull)
  sendLogs EmailSendLog[]
}

model EmailSendLog {
  id             String   @id @default(cuid())
  recipientEmail String
  subject        String
  templateId     String?
  automationId   String?
  bookingId      String?
  manual         Boolean  @default(false)
  sentAt         DateTime @default(now())

  automation EmailAutomation? @relation(fields: [automationId], references: [id], onDelete: SetNull)

  @@unique([automationId, bookingId, recipientEmail])
  @@index([recipientEmail])
  @@index([sentAt])
}

model SiteSettings {
  id                  String  @id @default("default")
  slotDurationMinutes Int     @default(180)
  googleReviewUrl     String?
}
