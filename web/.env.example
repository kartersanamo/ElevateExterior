# Site
NEXT_PUBLIC_SITE_URL=https://elevateexterior.org

# Database
DATABASE_URL="file:../data/db.sqlite"

# Auth
AUTH_SECRET=
AUTH_URL=https://elevateexterior.org

# Comma-separated emails; ADMIN_PASSWORD is a one-time temporary password per account
ADMIN_EMAILS=kartersanamo@gmail.comkylelesso@gmail.com
ADMIN_PASSWORD=ChangeMeNow!

# Mailgun — sends from @elevateexterior.org; inbound replies forward to CONTACT_TO_EMAIL
MAILGUN_API_KEY=
MAILGUN_DOMAIN=elevateexterior.org
MAILGUN_FROM=Elevate Exterior <noreply@elevateexterior.org>
MAILGUN_REPLY_TO=kartersanamo@gmail.com,kylelesso@gmail.com
CONTACT_TO_EMAIL=kartersanamo@gmail.com,kylelesso@gmail.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cron — call GET /api/cron/booking-reminders every 5 minutes
# Example: curl -H "Authorization: Bearer $CRON_SECRET" "$NEXT_PUBLIC_SITE_URL/api/cron/booking-reminders"
CRON_SECRET=

# Rate limits
CONTACT_RATE_LIMIT_PER_HOUR=5

# Google Business review link
GOOGLE_REVIEW_URL=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
