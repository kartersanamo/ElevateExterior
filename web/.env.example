# Site
NEXT_PUBLIC_SITE_URL=https://elevate.kartersanamo.com

# Database (SQLite — use file:./data/db.sqlite locally, file:/app/data/db.sqlite in Docker)
DATABASE_URL="file:./data/db.sqlite"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=https://elevate.kartersanamo.com

# Admin seed (used by npm run db:seed)
# Comma-separated for multiple co-founders; all share ADMIN_PASSWORD on first seed
ADMIN_EMAILS=kylelesso@gmail.com
ADMIN_PASSWORD=ChangeMeNow!

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM="Elevate Exterior <noreply@your-mailgun-domain>"
CONTACT_TO_EMAIL=kylelesso@gmail.com

# Stripe (payments on completed jobs)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Rate limits
CONTACT_RATE_LIMIT_PER_HOUR=5

# Cron (daily — Bearer token)
CRON_SECRET=
