# Site
NEXT_PUBLIC_SITE_URL=https://elevateexterior.org

# Database (SQLite — use file:./data/db.sqlite locally, file:/app/data/db.sqlite in Docker)
DATABASE_URL="file:./data/db.sqlite"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=https://elevateexterior.org

# Admin seed (used by npm run db:seed on first deploy only)
# Comma-separated emails; ADMIN_PASSWORD is a one-time temporary password per account
# (must be changed on first login). Re-running seed does not reset existing passwords.
ADMIN_EMAILS=kylelesso@gmail.com
ADMIN_PASSWORD=ChangeMeNow!

# Mailgun — outbound from @elevateexterior.org
MAILGUN_API_KEY=
MAILGUN_DOMAIN=elevateexterior.org
MAILGUN_FROM=Elevate Exterior <noreply@elevateexterior.org>
# Reply-To address; Mailgun forwards inbound replies to CONTACT_TO_EMAIL (routing only — not admin alerts)
MAILGUN_REPLY_TO=kylelesso@gmail.com
CONTACT_TO_EMAIL=kylelesso@gmail.com

# Admin email alerts are sent to co-founder accounts based on toggles at /admin/notifications

# Stripe (payments on completed jobs)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Rate limits
CONTACT_RATE_LIMIT_PER_HOUR=5

# Google Business review link (sent after payment)
GOOGLE_REVIEW_URL=

# Twilio SMS (optional — skipped when unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
